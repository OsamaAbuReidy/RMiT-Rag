# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Embeddings
# Supported values:
# - openai: uses OPENAI_API_KEY and OpenAI embeddings
# - deepseek: uses DEEPSEEK_API_KEY and the DeepSeek OpenAI-compatible base URL
# - openai_compatible: uses EMBEDDING_API_KEY and EMBEDDING_BASE_URL
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_EMBEDDING_MODEL=
DEEPSEEK_EMBEDDING_DIMENSIONS=1536

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=bnm_compliance_chunks

# Application
APP_ENV=local
LOG_LEVEL=INFO
